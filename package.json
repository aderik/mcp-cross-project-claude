{
  "name": "mcp-cross-project-claude",
  "version": "0.4.5",
  "description": "Encrypted LAN bridge between two Claude Code projects: ask read-only questions across project boundaries (and across machines) without pulling the other project's source into the caller's context.",
  "type": "module",
  "bin": {
    "mcp-cross-project-claude": "dist/index.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "bridge",
    "subagent",
    "cross-project"
  ],
  "author": "Aderik Teekman <aderik@live.nl>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aderik/mcp-cross-project-claude.git"
  },
  "homepage": "https://github.com/aderik/mcp-cross-project-claude#readme",
  "bugs": {
    "url": "https://github.com/aderik/mcp-cross-project-claude/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "bonjour-service": "^1.3.0",
    "noise-handshake": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3"
  }
}
