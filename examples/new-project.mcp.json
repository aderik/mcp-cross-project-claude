{
  "mcpServers": {
    "ask-legacy": {
      "command": "npx",
      "args": [
        "-y",
        "@aderik/mcp-cross-project-claude",
        "serve"
      ],
      "env": {
        "PROJECT_DIR": "/absolute/path/to/nieuwe-accelerate",
        "PROJECT_LABEL": "new-accelerate",
        "TOOL_NAME": "ask_legacy",
        "PEER_LABEL": "legacy-accelerate",
        "POSTURE_PRESET": "new",
        "CLAUDE_TIMEOUT_MS": "180000"
      }
    }
  }
}
